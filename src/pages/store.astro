---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

  <main class="max-w-2xl mx-auto px-6 py-20">

    <h1 class="text-4xl font-bold mb-4">
      Store
    </h1>

    <p class="text-gray-500 mb-12">
      Explore my music and digital products.
    </p>

    <div class="space-y-6">

      <a
        href="https://YOURNAME.bandcamp.com"
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-gray-200 rounded-xl p-8 hover:shadow-md transition"
      >
        <h2 class="text-2xl font-semibold">
          Bandcamp ↗
        </h2>

        <p class="mt-2 text-gray-500">
          Albums, EPs and Singles
        </p>
      </a>

      <a
        href="https://YOURNAME.booth.pm"
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-gray-200 rounded-xl p-8 hover:shadow-md transition"
      >
        <h2 class="text-2xl font-semibold">
          BOOTH ↗
        </h2>

        <p class="mt-2 text-gray-500">
          Sound Library and Downloads
        </p>
      </a>

    </div>

  </main>

</BaseLayout>