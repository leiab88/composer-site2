---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

  <main class="max-w-2xl mx-auto px-6 py-20">

    <h1 class="text-5xl font-bold mb-4 text-center">
      Contact
    </h1>

    <p class="text-center text-lg leading-relaxed mb-10">
      楽曲制作のご依頼・ご相談など、お気軽にお問い合わせください。<br />
      内容を確認のうえ、通常2〜3営業日以内にご返信いたします。
    </p>

    <form
      action="https://ssgform.com/s/0GgQJY90XFte"
      method="POST"
      class="space-y-6 bg-white/10 backdrop-blur-md rounded-2xl p-8"
    >

      <!-- お名前 -->
      <div>
        <label class="block mb-2 font-medium">
          お名前
        </label>

        <input
          type="text"
          name="name"
          required
          class="w-full p-3 rounded-lg border text-black"
        />
      </div>

      <!-- メールアドレス -->
      <div>
        <label class="block mb-2 font-medium">
          メールアドレス
        </label>

        <input
          type="email"
          name="email"
          required
          class="w-full p-3 rounded-lg border text-black"
        />
      </div>

      <!-- お問い合わせ内容 -->
      <div>
        <label class="block mb-2 font-medium">
          お問い合わせ内容
        </label>

        <textarea
          name="message"
          rows="7"
          required
          class="w-full p-3 rounded-lg border text-black"
        ></textarea>
      </div>

      <div class="text-center pt-4">
        <button
          type="submit"
          class="px-8 py-3 rounded-xl bg-white text-black font-bold shadow-lg hover:scale-105 transition-all duration-300"
        >
          ✉ 送信する
        </button>
      </div>

    </form>

  </main>

</BaseLayout>