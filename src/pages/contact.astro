---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

<section class="max-w-2xl mx-auto mt-20">
  <h2 class="text-3xl font-bold mb-4 text-center">
  Contact 
</h2>

<p class="text-center text-black/80 mb-6">
  楽曲制作のご依頼・ご相談はこちらからお気軽にお問い合わせください。<br>
  Feel free to contact me regarding music production and collaboration opportunities.
</p>

  <form
    action="https://formspree.io/f/xeebqyra"
    method="POST"
    class="bg-white/10 backdrop-blur-md rounded-2xl p-8 space-y-4"
  >
  <input
  type="hidden"
  name="_redirect"
  value="http://localhost:4321/thank-you"
/>

   <input
  type="text"
  name="name"
  placeholder="お名前"
  required
  class="w-full p-3 rounded-lg text-black"
/>

<input
  type="email"
  name="email"
  placeholder="メールアドレス"
  required
  class="w-full p-3 rounded-lg text-black"
/>

<textarea
  name="message"
  placeholder="お問い合わせ内容"
  rows="6"
  required
  class="w-full p-3 rounded-lg text-black"
></textarea>

<div class="text-center">
  <button
    type="submit"
    class="px-8 py-3 rounded-xl bg-white text-black font-bold shadow-lg hover:scale-105 transition-all duration-300"
  >
    ✉ 送信
  </button>
</div>

</BaseLayout>