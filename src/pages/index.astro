---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto mb-20">

    <img
      src="/images/hero-home.png"
      alt="Hero Image"
      class="w-full h-auto rounded-xl"
    />

  </section>

  <!-- Catch Copy -->
  <section class="max-w-3xl mx-auto text-center px-6 mb-24">

    <h1 class="text-4xl font-bold mb-6">
      Music for Games, Films & Stories
    </h1>

    <p class="text-lg leading-relaxed text-gray-600">
      BELUNE WORKSは、夜の都市や静かな空間、日常に潜む小さな違和感から着想を得て、<br>
      情景や物語が浮かぶ音楽を制作しています。オリジナル作品の発表を軸に、<br>
      映像・ゲーム・ブランドコンテンツ向けの楽曲制作も行っています。
    </p>

  </section>

  <!-- News -->

  <section class="max-w-3xl mx-auto px-6 mb-24">

    <h2 class="text-3xl font-bold mb-8">
      News
    </h2>

    <div class="space-y-6">

      <div class="border-b pb-4">
        <p class="text-sm text-gray-500">
          2026.07
        </p>

        <h3 class="text-xl font-semibold">
          Webサイトをオープンしました
        </h3>

        <p class="text-gray-600 mt-2">
          BELUNE WORKS公式ポートフォリオサイトを公開しました。
        </p>
      </div>

      <div class="border-b pb-4">
        <p class="text-sm text-gray-500">
          2026.07
        </p>

        <h3 class="text-xl font-semibold">
          YouTubeチャンネルを開設しました
        </h3>

        <p class="text-gray-600 mt-2">
          オリジナル楽曲や制作したBGMを公開していきます。
        </p>
      </div>

    </div>

  </section>

  <!-- Contact -->

  <section class="max-w-3xl mx-auto text-center px-6 mb-20">



  </section>

</BaseLayout>